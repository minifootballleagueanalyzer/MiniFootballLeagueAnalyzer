---
import Header from '../components/Header/Header';
import ChatbotWidget from '../components/ChatbotWidget/ChatbotWidget';
import '../index.css';
// IMPORTO el componente de analíticas de Vercel para registrar las visitas a la web
import Analytics from '@vercel/analytics/astro';

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" suppressHydrationWarning>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title || 'Mini Football League Analyzer'}</title>
    <link rel="icon" type="image/png" href="/MyGol_favicon.png" />
    <meta name="description" content="Análisis de ELO y estadísticas de la Mini Football League" />
</head>
<body>
    <div class="app-container">
        <!-- RENDERIZO el componente de Analytics de Vercel para que empiece a medir el tráfico del sitio -->
        <Analytics />
        <Header client:load />
        <main class="main-content">
            <slot />
        </main>
        <ChatbotWidget client:load />
    </div>
</body>
</html>

<style is:global>
    /* Estilos globales si son necesarios, o importar el index.css arriba */
</style>
